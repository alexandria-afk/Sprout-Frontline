# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (from supabase status or project dashboard)
SUPABASE_URL=

# Anon/public key — safe for frontend and mobile
SUPABASE_ANON_KEY=

# Service role key — BACKEND ONLY, never expose to frontend or mobile
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used to verify Supabase-issued tokens server-side
SUPABASE_JWT_SECRET=

# PostgreSQL direct connection URL (from supabase status)
DATABASE_URL=

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# Random hex secret for backend session signing — generated by setup-dev.sh
BACKEND_SECRET_KEY=

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# These NEXT_PUBLIC_ vars are safe to expose — they are the anon key only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI backend base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
